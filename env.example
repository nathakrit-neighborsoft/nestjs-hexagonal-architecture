# Application Configuration
NODE_ENV=development
PORT=9009
DEFAULT_TIME_ZONE=Asia/Bangkok

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres123
DB_DATABASE=expense_tracker_dev
DB_DIALECT=postgres

# Better Auth Configuration
BETTER_AUTH_URL=http://localhost:9009
BETTER_AUTH_SECRET=change-me-at-least-16-chars!!
TRUSTED_ORIGINS=http://localhost:3000

# Logging Configuration
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=*

# Swagger Configuration
SWAGGER_TITLE=Expense API
SWAGGER_DESCRIPTION=The Expense API description
SWAGGER_VERSION=1.0

#Logger config
PRETTY_LOG=true
